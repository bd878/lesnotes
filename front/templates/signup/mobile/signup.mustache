<div class="mt-2 max-w-md min-w-3xs w-full grow px-5">
	<div class="mb-3">
		{{> sidebar}}
	</div>

	<form
		action="{{action}}"
		method="POST"
		autoComplete="off"
		class="flex flex-col"
	>
		<div>
			{{> username}}
		</div>

		<div class="mt-2">
			{{> password}}
		</div>

		<div class="mt-2 text-sm small:text-xs large:text-md italic text-red-600 dark:text-red-400">{{error}}</div>

		<div class="mt-3">
			{{> submit}}
		</div>
	</form>
</div>
