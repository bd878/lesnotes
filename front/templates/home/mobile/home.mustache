<div class="h-full">
	<div class="flex flex-col overflow-x-hidden mb-5 small:mb-3 w-full max-w-md">
		{{> header}}
	</div>

	<div class="w-full h-full max-w-md max-h-[300px] flex flex-row mb-5 small:mb-3">
		<div class="flex flex-col grow-2 w-full h-full">
			{{> messageHeader}}
			<div class="w-full overflow-x-hidden border border-1 border-solid rounded-md h-full">
				{{> messageEditForm}}
				{{> messageView}}
				{{> newMessageForm}}
				{{> threadEditForm}}
				{{> threadView}}
			</div>
		</div>
	</div>

	{{# hasFeatures}}
		<div class="mb-5 small:mb-3">
			{{> messageFeatures}}
		</div>
	{{/ hasFeatures}}

	<div>
		{{> messagesTree}}
	</div>

	<div class="mb-5 small:mb-3">
		{{> controlPanel}}
	</div>
</div>