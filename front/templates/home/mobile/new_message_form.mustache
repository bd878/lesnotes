<form
	id="new-message-form"
	autocomplete="off"
	onsubmit="return false;"
	class="w-full h-full flex flex-row grow"
>
	<div class="h-full flex flex-col grow">
		<input name="title" class="focus:outline-none w-full small:placeholder:text-sm large:placeholder:text-xl small:text-sm large:text-xl resize-none px-1 placeholder:italic placeholder:text-gray-600 text-lg mb-2" placeholder="{{titlePlaceholder}}"></input>
		<textarea name="text" type="input" class="mb-2 focus:outline-none w-full px-1 overflow-y-auto resize-none placeholder:italic placeholder:text-gray-600 text-sm small:placeholder:text-sm large:placeholder:text-lg small:text-sm large:text-lg h-full" placeholder="{{textPlaceholder}}"></textarea>
		<input type="hidden" name="thread" value="{{threadID}}" />

		{{#hasFiles}}
			<div class="mb-2">
				{{> filesList}}
			</div>
		{{/hasFiles}}

		<div class="flex flex-row justify-between px-1 mb-1">
			{{#hasFiles}}
				<input class="hidden" id="files-input" type="file" multiple></input>

				<button id="select-files-button" type="button" class="cursor-pointer">
					<svg class="dark:stroke-gray-400 dark:hover:stroke-white stroke-black" width="24px" height="24px" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
						<path d="M6 7.90909V16C6 19.3137 8.68629 22 12 22V22C15.3137 22 18 19.3137 18 16V6C18 3.79086 16.2091 2 14 2V2C11.7909 2 10 3.79086 10 6V15.1818C10 16.2864 10.8954 17.1818 12 17.1818V17.1818C13.1046 17.1818 14 16.2864 14 15.1818V8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
					</svg>
				</button>
			{{/hasFiles}}

			<button type="submit" class="rounded-md border-1 px-2 border-solid text-left cursor-pointer">
				{{sendButton}}
			</button>
		</div>
	</div>
</form>