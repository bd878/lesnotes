<div class="h-full max-w-full flex flex-row">
	<div class="flex flex-col overflow-x-hidden mr-8 w-full min-w-sm max-w-xl">
		{{> header}}
		<div class="h-full overflow-y-hidden">
			{{> messagesTree}}
		</div>
		{{> controlPanel}}
	</div>

	<div class="w-full min-w-md max-w-2xl flex flex-row mr-8">
		<div class="flex flex-col grow-2 w-full">
			{{> messageHeader}}
			<div class="flex flex-col grow p-2 border border-1 border-solid rounded-md h-full">
				{{> messageEditForm}}
				{{> messageView}}
				{{> newMessageForm}}
				{{> translationEditForm}}
				{{> translationView}}
				{{> newTranslationForm}}
				{{> threadEditForm}}
				{{> threadView}}
				{{> filesList}}
				{{> pagination}}
				{{> filesForm}}
			</div>
		</div>
	</div>

	<div class="h-full flex flex-col max-w-xl min-w-sm w-full overflow-x-hidden">
		{{> messageNavigation}}
		{{> filesView}}
		{{> comments}}
	</div>
</div>