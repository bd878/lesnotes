<ul>
	{{#path}}
		<li>
			<a href="{{pathThreadHref}}" target="_self" class="hover:text-blue-600 flex items-center dark:hover:text-white underline cursor-pointer">{{threadTitle}}</a>
		</li>
	{{/path}}
	{{#lastMessage}}
		{{#lastThreadExternal}}
			<li class="flex flex-row justify-between">
				<a href="{{lastThreadHref}}" target="{{lastThreadTarget}}" class="grow-1 hover:text-blue-600 flex items-center dark:hover:text-white underline cursor-pointer">
					{{threadTitle}}
					<div class="ml-2">↗</div>
				</a>
		{{/lastThreadExternal}}
		{{^lastThreadExternal}}
			<li class="flex flex-row justify-between">
				<a href="{{lastThreadHref}}" target="{{lastThreadTarget}}" class="grow-1 hover:text-blue-600 hover:stroke-blue-600 flex items-center dark:hover:text-white underline cursor-pointer">
					{{threadTitle}}
				</a>
		{{/lastThreadExternal}}

			{{#editPublicThread}}
				<form
					method="POST"
					autocomplete="off"
					class="flex flex-row"
				>
					<input type="hidden" name="id" value="{{ID}}" />

					{{#threadPrivate}}
						<button formaction="{{publishThreadAction}}" type="submit" class="px-2 italic underline dark:hover:text-white hover:text-blue-600 select-text cursor-pointer text-end">{{publishThreadTitle}}</button>
					{{/threadPrivate}}
					{{^threadPrivate}}
						<button formaction="{{privateThreadAction}}" type="submit" class="px-2 italic underline dark:hover:text-white hover:text-blue-600 select-text cursor-pointer text-end">{{privateThreadTitle}}</button>
					{{/threadPrivate}}
				</form>
			{{/editPublicThread}}
		</li>
	{{/lastMessage}}
</ul>