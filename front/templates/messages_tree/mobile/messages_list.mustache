<div class="flex flex-col w-full max-w-lg">
	<div class="overflow-y-auto">
		<ul class="flex flex-col">
			{{#messages}}
				<li id="list-{{ID}}" data-message-id="{{ID}}" draggable="true" class="grow-1 max-w-full flex flex-col">
					<div class="flex flex-row max-w-full whitespace-nowrap justify-between">
						{{#highlight}}
							<a href="{{messageHref}}" target="_self" data-message-id="{{ID}}" class="flex flex-row justify-between overflow-hidden select-text dark:hover:bg-slate-600 dark:hover:text-white bg-blue-100 cursor-pointer text-left w-full z-1">
						{{/highlight}}
						{{^highlight}}
							<a href="{{messageHref}}" target="_self" data-message-id="{{ID}}" class="flex flex-row justify-between overflow-hidden select-text dark:hover:bg-slate-600 dark:hover:text-white hover:bg-gray-300 cursor-pointer text-left w-full z-1">
						{{/highlight}}

							<div class="overflow-hidden text-ellipsis mr-2" data-message-id="{{ID}}">
								{{#title}}
									{{title}}
								{{/title}}
								{{^title}}
									{{text}}
								{{/title}}
							</div>
						</a>

						<div class="flex">
							{{#isAuthed}}
								<a href="{{openThreadHref}}" target="_self" class="dark:hover:text-white px-4 cursor-pointer hover:bg-blue-100 dark:hover:bg-slate-600">
									{{#showCounter}}
										<span class="mr-1">{{count}}</span>
									{{/showCounter}}

									>>
								</a>
							{{/isAuthed}}
						</div>
					</div>
				</li>
			{{/messages}}
			{{^messages}}
				<li class="text-gray-600 italic">{{noMessagesText}}</li>
			{{/messages}}
		</ul>
	</div>

	{{#hasPagination}}
		<div class="flex flex-row mt-2">
			{{^isLastPage}}
				<a href="{{prevPageHref}}" target="_self" class="odd:mr-[4px] text-sm/6 text-center grow cursor-pointer dark:bg-slate-600 dark:hover:text-white bg-gray-300 last:mr-0"><-</a>
			{{/isLastPage}}

			{{^isFirstPage}}
				<a href="{{nextPageHref}}" target="_self" class="text-center text-sm/6 grow cursor-pointer dark:bg-slate-600 dark:hover:text-white bg-gray-300">-></a>
			{{/isFirstPage}}
		</div>
	{{/hasPagination}}
</div>
