<div class="flex flex-row mb-5">
	{{#isAttachments}}
		<a href="{{attachmentsHref}}" target="_self" class="hover:text-blue-600 flex items-center dark:hover:text-white underline cursor-pointer mr-2">{{attachments}}</a>
	{{/isAttachments}}
	{{#isComments}}
		<a href="{{commentsHref}}" target="_self" class="hover:text-blue-600 flex items-center dark:hover:text-white underline cursor-pointer ml-2">{{comments}}</a>
	{{/isComments}}
	{{#isTranslations}}
		<a href="{{translationsHref}}" target="_self" class="hover:text-blue-600 flex items-center dark:hover:text-white underline cursor-pointer ml-2">{{translations}}</a>
	{{/isTranslations}}
</div>