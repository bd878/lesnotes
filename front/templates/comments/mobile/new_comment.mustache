<div>
	<form
		autocomplete="off"
		method="POST"
		class="w-full flex flex-row grow"
	>
		<div class="flex flex-col grow">
			<input type="hidden" name="message" value="{{message}}" />
			<input type="hidden" name="redirectUrl" value="{{redirectUrl}}" />

			<textarea name="text" class="w-full px-1 dark:text-white large:text-lg small:text-sm large:placeholder:text-lg small:placeholder:text-sm border-1 border-gray-600 rounded-md overflow-y-auto wrap-break-word text-start resize-none px-1 placeholder:italic placeholder:text-gray-600 mb-2 rounded-md text-sm h-full" placeholder="{{newComment}}"></textarea>

			<div class="flex flex-row justfy-between">
				<button formaction="{{sendAction}}" type="submit" class="rounded-md dark:hover:text-white border-1 px-4 border-solid text-left cursor-pointer">
					{{sendAction}}
				</button>
			</div>
		</div>
	</form>
</div>